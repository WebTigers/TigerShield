<!-- Create/edit modal -->
<div class="modal fade" id="ts-rule-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form id="ts-rule-form" onsubmit="return false;" novalidate>
                <?php if (isset($this->form)) { echo $this->form->getElement('_csrf'); } ?>
                <input type="hidden" name="rule_id" value="">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa-solid fa-shield-halved me-2"></i><span id="ts-rule-modal-title">Add rule</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="ts-rule-modal-feedback"></div>
                    <div class="mb-3">
                        <label class="form-label" for="ts-rule-label">Label</label>
                        <input type="text" class="form-control" id="ts-rule-label" name="label" maxlength="191" placeholder="e.g. Block legacy admin path">
                        <div class="form-text">A short name — shown in Live Traffic as <code>waf: &lt;label&gt; (custom)</code>.</div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="ts-rule-target">Request surface</label>
                            <select class="form-select" id="ts-rule-target" name="target">
                                <?php foreach ($targets as $t): ?>
                                <option value="<?= htmlspecialchars($t) ?>"><?= htmlspecialchars($targetLabels[$t] ?? $t) ?></option>
                                <?php endforeach; ?>
                            </select>
                            <div class="form-text" id="ts-rule-target-help">&nbsp;</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="ts-rule-match">Match type</label>
                            <select class="form-select" id="ts-rule-match" name="match_type">
                                <?php foreach ($matches as $m): ?>
                                <option value="<?= htmlspecialchars($m) ?>"><?= htmlspecialchars($matchLabels[$m] ?? $m) ?></option>
                                <?php endforeach; ?>
                            </select>
                            <div class="form-text">Literal is fastest; regex is matched case-insensitively.</div>
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label" for="ts-rule-pattern">Pattern</label>
                        <input type="text" class="form-control font-monospace" id="ts-rule-pattern" name="pattern" maxlength="500" placeholder="e.g. /old-admin  or (?:acme|widgets)-exploit">
                        <div class="form-text">For regex, enter the expression body only — no <code>/</code> delimiters.</div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="ts-rule-action">Action on match</label>
                            <select class="form-select" id="ts-rule-action" name="action">
                                <?php foreach ($actions as $a): ?>
                                <option value="<?= htmlspecialchars($a) ?>"><?= htmlspecialchars($actionLabels[$a] ?? $a) ?></option>
                                <?php endforeach; ?>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="ts-rule-order">Order</label>
                            <input type="number" class="form-control" id="ts-rule-order" name="sort_order" value="100" min="0" max="9999">
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" role="switch" id="ts-rule-enabled" name="enabled" value="1" checked>
                                <label class="form-check-label" for="ts-rule-enabled">Enabled</label>
                            </div>
                        </div>
                    </div>
                    <p class="form-text mb-0"><i class="fa-solid fa-circle-info me-1"></i>Body scanning (surface <em>POST body</em>) also requires the global body-scan toggle, or a body rule turns it on for itself.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="ts-rule-save" class="btn btn-primary"><i class="fa-solid fa-floppy-disk me-2"></i>Save rule</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    if (typeof tigerDataTable !== 'function') { return; }
    var $   = jQuery;
    var esc = tigerDataTable.esc;

    var TARGET = <?= json_encode($targetLabels) ?>;
    var MATCH  = <?= json_encode($matchLabels) ?>;
    var ACTION = <?= json_encode($actionLabels) ?>;
    var ABADGE = { log: 'secondary', captcha: 'warning', block: 'danger' };
    var HELP   = {
        path: 'The decoded URL path only.', query: 'The decoded query string only.',
        pathquery: 'Path and query together.', ua: 'The User-Agent header.',
        method: 'The HTTP method (GET, POST, …) — use with a literal match.',
        body: 'Form-encoded POST field values (needs body scanning on).'
    };

    var modalEl = document.getElementById('ts-rule-modal');
    var modal   = new bootstrap.Modal(modalEl);
    var form    = document.getElementById('ts-rule-form');
    var fb      = document.getElementById('ts-rules-feedback');
    var mfb     = document.getElementById('ts-rule-modal-feedback');

    var table = tigerDataTable('#ts-rules-table', {
        service: { module: 'tigershield', service: 'rules', action: 'datatable' },
        order: [[0, 'asc']],
        language: { search: '', searchPlaceholder: 'Search label or pattern…', emptyTable: 'No custom rules yet — add one to get started.' },
        columns: [
            { data: 'label', render: function (t, type) { return type !== 'display' ? t : esc(t || '—'); } },
            { data: 'target', orderable: false, render: function (t, type) {
                return type !== 'display' ? t : '<span class="badge text-bg-light">' + esc(TARGET[t] || t) + '</span>';
            } },
            { data: 'match', orderable: false, render: function (t, type) {
                return type !== 'display' ? t : esc(MATCH[t] || t);
            } },
            { data: 'pattern', orderable: false, render: function (t, type) {
                return type !== 'display' ? t : '<code class="text-body-secondary">' + esc(t || '') + '</code>';
            } },
            { data: 'action', orderable: false, render: function (t, type) {
                return type !== 'display' ? t : '<span class="badge text-bg-' + (ABADGE[t] || 'secondary') + '">' + esc(ACTION[t] || t) + '</span>';
            } },
            { data: 'enabled', className: 'text-center', orderable: false, render: function (t, type, row) {
                if (type !== 'display') { return t; }
                var on = String(t) === '1';
                return '<div class="form-check form-switch d-inline-block m-0">' +
                    '<input class="form-check-input ts-rule-toggle" type="checkbox" role="switch" data-id="' + esc(row.rule_id) + '"' + (on ? ' checked' : '') + '></div>';
            } },
            { data: null, orderable: false, className: 'text-end text-nowrap', render: function (row) {
                return '<button type="button" class="btn btn-sm btn-outline-secondary ts-rule-edit me-1" title="Edit"><i class="fa-solid fa-pen"></i></button>' +
                    '<button type="button" class="btn btn-sm btn-outline-danger ts-rule-del" title="Delete"><i class="fa-solid fa-trash"></i></button>';
            } }
        ]
    });

    function post(method, extra, btn, done) {
        var fd = new URLSearchParams();
        fd.set('module', 'tigershield'); fd.set('service', 'rules'); fd.set('method', method);
        Object.keys(extra).forEach(function (k) { fd.set(k, extra[k]); });
        var run = function () {
            return fetch('/api', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd })
                .then(function (r) { return r.json().catch(function () { return {}; }); });
        };
        var chain = btn ? TigerButton.run(btn, run) : run();
        chain.then(done).catch(function () { TigerDOM.notify(fb, 'Network error — please try again.', { type: 'error' }); });
    }

    function openModal(row) {
        form.reset();
        mfb.innerHTML = '';
        form.querySelectorAll('.is-invalid').forEach(function (el) { el.classList.remove('is-invalid'); });
        form.querySelector('[name="rule_id"]').value = row ? row.rule_id : '';
        document.getElementById('ts-rule-modal-title').textContent = row ? 'Edit rule' : 'Add rule';
        if (row) {
            document.getElementById('ts-rule-label').value    = row.label || '';
            document.getElementById('ts-rule-target').value   = row.target || 'query';
            document.getElementById('ts-rule-match').value    = row.match || 'contains';
            document.getElementById('ts-rule-pattern').value  = row.pattern || '';
            document.getElementById('ts-rule-action').value   = row.action || 'log';
            document.getElementById('ts-rule-enabled').checked = String(row.enabled) === '1';
        }
        syncTargetHelp();
        modal.show();
    }

    function syncTargetHelp() {
        var t = document.getElementById('ts-rule-target').value;
        document.getElementById('ts-rule-target-help').textContent = HELP[t] || ' ';
    }
    document.getElementById('ts-rule-target').addEventListener('change', syncTargetHelp);

    document.getElementById('ts-rule-add').addEventListener('click', function () { openModal(null); });

    document.getElementById('ts-rule-save').addEventListener('click', function () {
        var extra = {
            rule_id:    form.querySelector('[name="rule_id"]').value,
            label:      document.getElementById('ts-rule-label').value,
            target:     document.getElementById('ts-rule-target').value,
            match_type: document.getElementById('ts-rule-match').value,
            pattern:    document.getElementById('ts-rule-pattern').value,
            action:     document.getElementById('ts-rule-action').value,
            sort_order: document.getElementById('ts-rule-order').value,
            enabled:    document.getElementById('ts-rule-enabled').checked ? '1' : '0'
        };
        var csrf = form.querySelector('[name="_csrf"]');
        if (csrf) { extra._csrf = csrf.value; }
        post('save', extra, this, function (res) {
            if (res && res.result === 1) {
                modal.hide();
                table.ajax.reload(null, false);
                TigerDOM.notify(fb, 'Rule saved.', { type: 'success' });
                return;
            }
            (res && res.messages || []).forEach(function (m) { TigerDOM.notify(mfb, m.message, { type: m.class }); });
        });
    });

    // Row actions (delegated — the grid re-renders on every draw).
    $('#ts-rules-table tbody').on('click', '.ts-rule-edit', function () {
        openModal(table.row($(this).closest('tr')).data());
    });
    $('#ts-rules-table tbody').on('click', '.ts-rule-del', function () {
        var row = table.row($(this).closest('tr')).data();
        if (!row || !window.confirm('Delete rule "' + (row.label || '') + '"? This cannot be undone.')) { return; }
        post('delete', { rule_id: row.rule_id }, this, function (res) {
            if (res && res.result === 1) { table.ajax.reload(null, false); TigerDOM.notify(fb, 'Rule deleted.', { type: 'success' }); }
            else { (res && res.messages || []).forEach(function (m) { TigerDOM.notify(fb, m.message, { type: m.class }); }); }
        });
    });
    $('#ts-rules-table tbody').on('change', '.ts-rule-toggle', function () {
        var id = this.getAttribute('data-id');
        var enabled = this.checked ? '1' : '0';
        post('toggle', { rule_id: id, enabled: enabled }, null, function (res) {
            if (!res || res.result !== 1) {
                table.ajax.reload(null, false);
                TigerDOM.notify(fb, (res && res.messages && res.messages[0] ? res.messages[0].message : 'Could not update rule.'), { type: 'error' });
            }
        });
    });
});
</script>
