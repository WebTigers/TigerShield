/**
 * TigerShield — Custom Rules. A server-side DataTables grid of admin-authored WAF rules
 * (Tigershield_Service_Rules::datatable over /api) plus a create/edit modal that writes through the
 * same service (validate → save → recompile the gate cache). Rendered in the admin shell per ADMIN.md.
 *
 * A custom rule matches one request SURFACE (path/query/…/body) by a literal substring or a regex, and
 * carries its OWN action (log/captcha/block) — unlike the shipped soft heuristics, it isn't tier-capped.
 * Rules run AFTER the shipped ruleset (first match wins).
 */
$targets = isset($this->targets) ? $this->targets : ['path', 'query', 'pathquery', 'ua', 'method', 'body'];
$matches = isset($this->matches) ? $this->matches : ['contains', 'regex'];
$actions = isset($this->actions) ? $this->actions : ['log', 'captcha', 'block'];

$targetLabels = [
    'path' => 'URL path', 'query' => 'Query string', 'pathquery' => 'Path + query',
    'ua' => 'User-Agent', 'method' => 'HTTP method', 'body' => 'POST body',
];
$matchLabels  = ['contains' => 'Contains (literal)', 'regex' => 'Regex'];
$actionLabels = ['log' => 'Log only', 'captcha' => 'Challenge (captcha)', 'block' => 'Block'];
?>
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
