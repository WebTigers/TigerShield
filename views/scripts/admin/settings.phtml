$s    = isset($this->settings) ? $this->settings : [];
$get  = function ($path, $default = '') use ($s) {
    $node = $s; foreach (explode('.', $path) as $k) { if (!is_array($node) || !array_key_exists($k, $node)) { return $default; } $node = $node[$k]; }
    return is_scalar($node) ? (string) $node : $default;
};
$mode = $get('mode', 'learn');
$cs   = isset($this->crowdsec) && is_array($this->crowdsec) ? $this->crowdsec : [];
